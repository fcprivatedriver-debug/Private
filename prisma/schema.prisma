generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ——— Auth (Auth.js) ———

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum HouseholdKind {
  INDIVIDUAL
  COUPLE
  FAMILY
  SHARED
}

enum FinanceScope {
  PERSONAL
  FAMILY
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  MB_WAY
  TRANSFER
  DIRECT_DEBIT
  REVOLUT
  OTHER
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH
  WALLET
  INVESTMENT
  OTHER
}

enum BudgetAlertLevel {
  SEVENTY_FIVE
  NINETY
  HUNDRED
}

enum AlertType {
  BUDGET_THRESHOLD
  UNUSUAL_SPENDING
  RECURRING_DUE
  BILL_DUE
  GOAL_NEAR
  CUSTOM
}

enum ImportProvider {
  CONTINENTE
  PINGO_DOCE
  LIDL_PLUS
  MERCADONA
  AUCHAN
  REPSOL
  GALP
  PRIO
  VIA_VERDE
  TESLA
  MB_WAY
  REVOLUT
  OPEN_BANKING
  PDF
  CSV
  EMAIL
  MANUAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  READY_REVIEW
  IMPORTED
  FAILED
}

enum ConnectionKind {
  BANKING
  CARD
  WALLET
  EMAIL
  RETAIL
  LOYALTY
  FUEL
  AUTO
  UTILITY
  TELECOM
  INSURANCE
  TAX
  INVESTMENT
  OTHER
}

enum ConnectionStatus {
  AUTHORIZED
  PAUSED
  ERROR
}

enum AutomationLevel {
  VOICE
  VOICE_OCR
  VOICE_EMAIL
  VOICE_BANK
  VOICE_BANK_EMAIL_RETAIL
  FULL
}

enum GoalType {
  CAR
  HOUSE
  VACATION
  EMERGENCY
  INVESTMENT
  RETIREMENT
  CUSTOM
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  pinHash       String?
  biometricsEnabled Boolean @default(false)
  theme         String    @default("system") // light | dark | system
  locale        String    @default("pt")
  automationLevel AutomationLevel @default(VOICE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      AuthAccount[]
  sessions      Session[]
  memberships   FamilyMember[]
  createdIncomes Income[]  @relation("IncomeCreator")
  createdExpenses Expense[] @relation("ExpenseCreator")
  alerts        Alert[]
  aiInsights    AiInsight[]
  memoryRules   NinaMemoryRule[]
  habitStats    NinaHabitStat[]
  invitesCreated FamilyInvite[] @relation("InviteCreator")
  connections   NinaConnection[]
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ——— Família ———

model Family {
  id         String        @id @default(cuid())
  name       String
  kind       HouseholdKind @default(FAMILY)
  inviteCode String?       @unique
  currency   String        @default("EUR")
  timezone   String        @default("Europe/Lisbon")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  members            FamilyMember[]
  accounts           FinanceAccount[]
  categories         Category[]
  incomes            Income[]
  expenses           Expense[]
  budgets            Budget[]
  goals              SavingsGoal[]
  recurringPayments  RecurringPayment[]
  alerts             Alert[]
  importJobs         ImportJob[]
  aiInsights         AiInsight[]
  stores             Store[]
  invites            FamilyInvite[]
  memoryRules        NinaMemoryRule[]
  habitStats         NinaHabitStat[]
  connections        NinaConnection[]
}

model FamilyMember {
  id        String     @id @default(cuid())
  familyId  String
  userId    String
  displayName String
  photoUrl  String?
  role      FamilyRole @default(MEMBER)
  color     String     @default("#1e3a5f")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes  Income[]
  expenses Expense[]
  personalGoals SavingsGoal[] @relation("PersonalGoalOwner")

  @@unique([familyId, userId])
  @@index([userId])
}

model FamilyInvite {
  id           String    @id @default(cuid())
  familyId     String
  token        String    @unique
  createdById  String
  label        String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedById String?
  createdAt    DateTime  @default(now())

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy User   @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([familyId])
  @@index([token])
}

model NinaMemoryRule {
  id            String   @id @default(cuid())
  userId        String
  familyId      String?
  triggerPhrase String
  scope         FinanceScope?
  categorySlug  String?
  notes         String?
  isActive      Boolean  @default(true)
  hitCount      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model NinaHabitStat {
  id                  String   @id @default(cuid())
  userId              String
  familyId            String
  keyType             String   // store | category | phrase
  keyValue            String
  personalCount       Int      @default(0)
  familyCount         Int      @default(0)
  lastScope           FinanceScope?
  lastUsedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId, keyType, keyValue])
  @@index([userId, familyId])
}

/// Ligação opcional a um serviço externo — só ativa com autorização explícita.
model NinaConnection {
  id            String           @id @default(cuid())
  familyId      String
  userId        String
  providerKey   String
  label         String
  kind          ConnectionKind   @default(OTHER)
  status        ConnectionStatus @default(AUTHORIZED)
  autoImport    Boolean          @default(true)
  importProvider ImportProvider?
  lastSyncAt    DateTime?
  lastMessage   String?
  metadataJson  String?          @db.Text
  authorizedAt  DateTime         @default(now())
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, providerKey])
  @@index([familyId, status])
  @@index([userId])
}

// ——— Contas ———

model FinanceAccount {
  id        String      @id @default(cuid())
  familyId  String
  name      String
  type      AccountType @default(CHECKING)
  bankName  String?
  ibanMasked String?
  balanceCents Int      @default(0)
  currency  String      @default("EUR")
  color     String      @default("#1e3a5f")
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  family              Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  incomes             Income[]
  expenses            Expense[]
  recurringPayments   RecurringPayment[]

  @@index([familyId])
}

// ——— Categorias ———

model Category {
  id          String   @id @default(cuid())
  familyId    String
  name        String
  slug        String
  icon        String?
  color       String   @default("#64748b")
  kind        TransactionType @default(EXPENSE)
  isSystem    Boolean  @default(false)
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family      Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  incomes     Income[]
  expenses    Expense[]  @relation("ExpenseCategory")
  expenseSubs Expense[]  @relation("ExpenseSubcategory")
  budgets     Budget[]
  recurringPayments RecurringPayment[]

  @@unique([familyId, slug])
  @@index([familyId, kind])
}

// ——— Receitas ———

model Income {
  id          String       @id @default(cuid())
  familyId    String
  memberId    String?
  accountId   String?
  categoryId  String
  createdById String?
  scope       FinanceScope @default(PERSONAL)
  amountCents Int
  currency    String       @default("EUR")
  date        DateTime
  description String
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  family    Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member    FamilyMember?   @relation(fields: [memberId], references: [id])
  account   FinanceAccount? @relation(fields: [accountId], references: [id])
  category  Category        @relation(fields: [categoryId], references: [id])
  createdBy User?           @relation("IncomeCreator", fields: [createdById], references: [id])

  @@index([familyId, date])
  @@index([familyId, scope])
  @@index([categoryId])
}

// ——— Despesas ———

model Expense {
  id              String        @id @default(cuid())
  familyId        String
  memberId        String?
  accountId       String?
  categoryId      String
  subcategoryId   String?
  storeId         String?
  createdById     String?
  scope           FinanceScope  @default(PERSONAL)
  amountCents     Int
  currency        String        @default("EUR")
  date            DateTime
  time            String?
  description     String
  storeName       String?
  paymentMethod   PaymentMethod @default(DEBIT_CARD)
  notes           String?
  receiptImageUrl String?
  receiptPdfUrl   String?
  latitude        Float?
  longitude       Float?
  vatCents        Int?
  ocrRawJson      String?       @db.Text
  importJobId     String?
  isRecurringInstance Boolean   @default(false)
  recurringPaymentId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  family       Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member       FamilyMember?      @relation(fields: [memberId], references: [id])
  account      FinanceAccount?    @relation(fields: [accountId], references: [id])
  category     Category           @relation("ExpenseCategory", fields: [categoryId], references: [id])
  subcategory  Category?          @relation("ExpenseSubcategory", fields: [subcategoryId], references: [id])
  store        Store?             @relation(fields: [storeId], references: [id])
  createdBy    User?              @relation("ExpenseCreator", fields: [createdById], references: [id])
  importJob    ImportJob?         @relation(fields: [importJobId], references: [id])
  recurring    RecurringPayment?  @relation(fields: [recurringPaymentId], references: [id])
  lineItems    ExpenseLineItem[]

  @@index([familyId, date])
  @@index([familyId, scope])
  @@index([categoryId])
  @@index([storeName])
  @@index([paymentMethod])
}

model ExpenseLineItem {
  id          String  @id @default(cuid())
  expenseId   String
  name        String
  quantity    Float   @default(1)
  unitCents   Int
  totalCents  Int
  vatRate     Float?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model Store {
  id        String   @id @default(cuid())
  familyId  String
  name      String
  normalizedName String
  createdAt DateTime @default(now())

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([familyId, normalizedName])
  @@index([familyId])
}

// ——— Orçamentos ———

model Budget {
  id          String   @id @default(cuid())
  familyId    String
  categoryId  String
  year        Int
  month       Int
  limitCents  Int
  alert75     Boolean  @default(true)
  alert90     Boolean  @default(true)
  alert100    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family   Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([familyId, categoryId, year, month])
  @@index([familyId, year, month])
}

// ——— Objetivos de poupança ———

model SavingsGoal {
  id              String       @id @default(cuid())
  familyId        String
  ownerMemberId   String?
  scope           FinanceScope @default(FAMILY)
  name            String
  type            GoalType     @default(CUSTOM)
  targetCents     Int
  currentCents    Int          @default(0)
  deadline        DateTime?
  color           String       @default("#0f7a4a")
  icon            String?
  notes           String?
  isCompleted     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  family Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  owner  FamilyMember? @relation("PersonalGoalOwner", fields: [ownerMemberId], references: [id])

  @@index([familyId])
  @@index([familyId, scope])
}

// ——— Pagamentos recorrentes ———

model RecurringPayment {
  id            String              @id @default(cuid())
  familyId      String
  categoryId    String
  accountId     String?
  name          String
  amountCents   Int
  frequency     RecurrenceFrequency @default(MONTHLY)
  dayOfMonth    Int?
  nextDueDate   DateTime
  paymentMethod PaymentMethod       @default(DIRECT_DEBIT)
  isActive      Boolean             @default(true)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  family   Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category Category        @relation(fields: [categoryId], references: [id])
  account  FinanceAccount? @relation(fields: [accountId], references: [id])
  expenses Expense[]

  @@index([familyId, nextDueDate])
}

// ——— Alertas ———

model Alert {
  id          String    @id @default(cuid())
  familyId    String
  userId      String?
  type        AlertType
  title       String
  message     String
  level       String    @default("info") // info | warning | danger | success
  isRead      Boolean   @default(false)
  metadata    String?   @db.Text
  createdAt   DateTime  @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([familyId, isRead])
}

// ——— Importações ———

model ImportJob {
  id           String         @id @default(cuid())
  familyId     String
  provider     ImportProvider
  status       ImportStatus   @default(PENDING)
  sourceLabel  String?
  rawPayload   String?        @db.Text
  parsedJson   String?        @db.Text
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([familyId, status])
}

// ——— IA ———

model AiInsight {
  id        String   @id @default(cuid())
  familyId  String
  userId    String?
  kind      String
  title     String
  body      String   @db.Text
  severity  String   @default("info")
  dataJson  String?  @db.Text
  createdAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([familyId, createdAt])
}
