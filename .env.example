# ZRIK environment example (PostgreSQL / Neon)

# Pooled connection used by the app at runtime (Neon "pooled" / -pooler host)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct connection used by Prisma Migrate (Neon "direct" host, no -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Local PostgreSQL example:
# DATABASE_URL="postgresql://movio:movio@127.0.0.1:5432/movio?schema=public"
# DIRECT_URL="postgresql://movio:movio@127.0.0.1:5432/movio?schema=public"

AUTH_SECRET="generate-a-long-random-secret"
# REQUIRED on Vercel — without AUTH_SECRET Auth.js shows:
# "Server error. There is a problem with the server configuration."
AUTH_TRUST_HOST="true"

# Optional Google OAuth
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

PAYMENTS_ENABLED="false"
PLATFORM_FEE_PERCENT="15"
NEXT_PUBLIC_APP_NAME="ZRIK"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Demo / E2E — emails always land in /pt/demo/emails (EmailLog).
# Set RESEND_API_KEY to also deliver real messages.
DEMO_MODE="true"
# RESEND_API_KEY=
# EMAIL_FROM="ZRIK <onboarding@resend.dev>"
# NEXTAUTH_URL="https://your-domain.example"

# Stripe sandbox / live (optional). Keep PAYMENTS_ENABLED=false for zero-charge demo.
# PAYMENTS_ENABLED="true"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET=
# CRON_SECRET=
